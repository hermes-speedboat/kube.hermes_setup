# Copy to ../hermes.env and edit.
# Do not commit real hermes.env files.

# Kubernetes
HERMES_NAMESPACE=hermes
KUBECONFIG=${KUBECONFIG:-$HOME/.kube/config}

# Public DNS names. Replace with your own FQDNs.
WEBUI_HOST=hermes.example.com
DASHBOARD_HOST=hermes-admin.example.com

# Ingress
INGRESS_CLASS_NAME=traefik
# Optional outer Traefik BasicAuth middleware. Disable for trusted labs/VPN-only setups.
ENABLE_TRAEFIK_BASIC_AUTH=false
TRAEFIK_ENTRYPOINT=websecure
TLS_ENABLED=true
TLS_SECRET_NAME=

# Images. Pin tags in production instead of using latest.
HERMES_AGENT_IMAGE=nousresearch/hermes-agent:latest
HERMES_WEBUI_IMAGE=ghcr.io/nesquena/hermes-webui:latest
HERMES_BROWSER_IMAGE=ghcr.io/browserless/chromium:latest

# Storage
HERMES_HOME_STORAGE_SIZE=10Gi
HERMES_WORKSPACE_STORAGE_SIZE=20Gi
STORAGE_CLASS_NAME=

# Runtime UID/GID used for shared PVC ownership.
# Default 10000 matches the current nousresearch/hermes-agent image behavior.
HERMES_RUNTIME_UID=10000
HERMES_RUNTIME_GID=10000

# WebUI upload cap in MiB. Upstream default is 20; this installer defaults to 220 so 200MB files fit with multipart overhead.
HERMES_WEBUI_MAX_UPLOAD_MB=220

# Initial model config. OpenAI Codex still requires manual OAuth pairing.
MODEL_PROVIDER=codex
MODEL_NAME=gpt-5.5

# Outer Ingress BasicAuth. Used only when ENABLE_TRAEFIK_BASIC_AUTH=true.
# Leave password empty to let install.sh generate one. For simple lab passwords set HERMES_PASSWORD_POLICY=lab when rotating.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=

# Dashboard internal BasicAuth. The same password is also injected into WebUI as HERMES_WEBUI_PASSWORD.
# This avoids remote WebUI first-password onboarding. Leave empty to let install.sh generate one.
DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASSWORD=

# API server key. Leave empty to auto-generate.
API_SERVER_KEY=

# Browserless token. Leave empty to auto-generate.
BROWSER_TOKEN=

# Resource knobs
BROWSER_CONCURRENT=1
BROWSER_QUEUED=10
BROWSER_TIMEOUT_MS=300000

# Kubernetes resource requests/limits. Example values are lab-friendly for small K3s clusters; raise them for production/heavy workloads.
HERMES_AGENT_CPU_REQUEST=100m
HERMES_AGENT_MEMORY_REQUEST=256Mi
HERMES_AGENT_CPU_LIMIT=1
HERMES_AGENT_MEMORY_LIMIT=1Gi
HERMES_DASHBOARD_CPU_REQUEST=100m
HERMES_DASHBOARD_MEMORY_REQUEST=96Mi
HERMES_DASHBOARD_CPU_LIMIT=1
HERMES_DASHBOARD_MEMORY_LIMIT=1Gi
HERMES_WEBUI_CPU_REQUEST=100m
HERMES_WEBUI_MEMORY_REQUEST=256Mi
HERMES_WEBUI_CPU_LIMIT=1
HERMES_WEBUI_MEMORY_LIMIT=1Gi
HERMES_BROWSER_CPU_REQUEST=100m
HERMES_BROWSER_MEMORY_REQUEST=128Mi
HERMES_BROWSER_CPU_LIMIT=1
HERMES_BROWSER_MEMORY_LIMIT=1Gi

# Optional bootstrap. Copy examples/bootstrap to ./bootstrap, edit it, then set HERMES_BOOTSTRAP_DIR.
# Mode: disabled, missing, or overwrite. auth.json is excluded unless explicitly enabled.
HERMES_BOOTSTRAP_DIR=
HERMES_BOOTSTRAP_MODE=missing
HERMES_BOOTSTRAP_INCLUDE_AUTH=false

# Optional persistent Python addon venv for extra CLI/tools without rebuilding the image.
# If HERMES_ADDON_REQUIREMENTS points to a local requirements.txt, install.sh packages it
# into the init Secret and installs it into HERMES_ADDON_VENV on the /opt/data PVC.
HERMES_ADDON_REQUIREMENTS=
HERMES_ADDON_VENV=/opt/data/addon-venv

# Password policy for maintain.sh rotate-passwords: production or lab.
HERMES_PASSWORD_POLICY=production
