# Copy to ../hermes.env or use with ENV_FILE=./hermes.env ./install.sh
# Do not commit real hermes.env files.

# =====================================================================
# REQUIRED SETTINGS
# =====================================================================

# Kubernetes namespace for all Hermes resources.
HERMES_NAMESPACE=hermes

# Path to your kubeconfig. Defaults to ~/.kube/config.
# KUBECONFIG=${KUBECONFIG:-$HOME/.kube/config}

# =====================================================================
# COMPONENT TOGGLES
# =====================================================================
# Agent is mandatory. Dashboard, WebUI, and Browser are independently
# optional. Set to false to omit the corresponding deployment.

HERMES_AGENT_ENABLED=true
HERMES_DASHBOARD_ENABLED=true
HERMES_WEBUI_ENABLED=true
HERMES_BROWSER_ENABLED=true

# =====================================================================
# PUBLIC DNS NAMES
# =====================================================================
# Replace with your real FQDNs. Required when the corresponding
# component is enabled.

WEBUI_HOST=hermes.example.com
DASHBOARD_HOST=hermes-admin.example.com

# =====================================================================
# INGRESS / TLS
# =====================================================================
# Standard Kubernetes Ingress with Traefik defaults. Change
# INGRESS_CLASS_NAME for other ingress controllers.

INGRESS_CLASS_NAME=traefik
TRAEFIK_ENTRYPOINT=websecure
TLS_ENABLED=true
TLS_SECRET_NAME=

# =====================================================================
# CONTAINER IMAGES
# =====================================================================
# Pin tags in production instead of using latest.

HERMES_AGENT_IMAGE=nousresearch/hermes-agent:latest
HERMES_WEBUI_IMAGE=ghcr.io/nesquena/hermes-webui:latest
HERMES_BROWSER_IMAGE=ghcr.io/browserless/chromium:latest

# =====================================================================
# PERSISTENT STORAGE
# =====================================================================
# PVC sizes for /opt/data (home) and /workspace. Leave STORAGE_CLASS_NAME
# empty to use the cluster default.

HERMES_HOME_STORAGE_SIZE=10Gi
HERMES_WORKSPACE_STORAGE_SIZE=20Gi
STORAGE_CLASS_NAME=

# =====================================================================
# RUNTIME UID / GID
# =====================================================================
# Shared PVC ownership used by init containers, fsGroup, and WebUI
# runtime mapping. Agent/Dashboard/WebUI share /opt/data.

HERMES_RUNTIME_UID=10000
HERMES_RUNTIME_GID=10000

# =====================================================================
# WEBUI UPLOAD LIMIT
# =====================================================================
# Upstream default is 20MiB. This installer sets 220MiB so that
# 200MB-class documents can be uploaded with multipart overhead.

HERMES_WEBUI_MAX_UPLOAD_MB=220

# =====================================================================
# INITIAL MODEL CONFIGURATION
# =====================================================================
# Codex/OpenAI still requires manual OAuth pairing after installation.

MODEL_PROVIDER=codex
MODEL_NAME=gpt-5.6-luna

# =====================================================================
# DASHBOARD / WEBUI AUTHENTICATION
# =====================================================================
# The same password is used for both Dashboard and WebUI. Leave
# DASHBOARD_AUTH_PASSWORD empty to let install.sh generate one.

DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASSWORD=

# =====================================================================
# INTERNAL SECRETS
# =====================================================================
# Leave empty to auto-generate during installation.

API_SERVER_KEY=
BROWSER_TOKEN=

# =====================================================================
# BROWSERLESS RESOURCE KNOBS
# =====================================================================
# BROWSER_CONCURRENT=4 is the minimum recommended for parallel WebUI
# screenshot/browser workflows. Lower values can cause CDP timeouts.

BROWSER_CONCURRENT=4
BROWSER_QUEUED=10
BROWSER_TIMEOUT_MS=30000

# =====================================================================
# KUBERNETES RESOURCE REQUESTS / LIMITS
# =====================================================================
# Lab-friendly defaults for small K3s clusters. Raise for production.

HERMES_AGENT_CPU_REQUEST=100m
HERMES_AGENT_MEMORY_REQUEST=256Mi
HERMES_AGENT_CPU_LIMIT=1
HERMES_AGENT_MEMORY_LIMIT=1Gi
HERMES_DASHBOARD_CPU_REQUEST=100m
HERMES_DASHBOARD_MEMORY_REQUEST=96Mi
HERMES_DASHBOARD_CPU_LIMIT=1
HERMES_DASHBOARD_MEMORY_LIMIT=1Gi
HERMES_WEBUI_CPU_REQUEST=100m
HERMES_WEBUI_MEMORY_REQUEST=256Mi
HERMES_WEBUI_CPU_LIMIT=1
HERMES_WEBUI_MEMORY_LIMIT=1Gi
HERMES_BROWSER_CPU_REQUEST=100m
HERMES_BROWSER_MEMORY_REQUEST=128Mi
HERMES_BROWSER_CPU_LIMIT=1
HERMES_BROWSER_MEMORY_LIMIT=1Gi

# =====================================================================
# BOOTSTRAP PROFILE / DIRECTORY
# =====================================================================
# HERMES_BOOTSTRAP_PROFILE selects a prebuilt profile:
#   personal-assistant:       markdown-pdf + workspace manager, no SSH/Ansible
#   universal-system-architect: all skills, Ansible, SSH key
# Profile defaults apply only when the corresponding HERMES_* variable
# is omitted from this file.
# HERMES_BOOTSTRAP_DIR overrides profile composition entirely.

HERMES_BOOTSTRAP_PROFILE=personal-assistant
HERMES_BOOTSTRAP_DIR=

# Bootstrap modes:
#   missing:   copy only files that do not exist on the PVC (default, safe for upgrades)
#   overwrite: replace all bootstrap-managed files on the PVC
#   disabled:  ignore HERMES_BOOTSTRAP_DIR
HERMES_BOOTSTRAP_MODE=missing

# Include auth.json in the bootstrap archive. Only enable when
# deliberately restoring OAuth state from a protected source.
HERMES_BOOTSTRAP_INCLUDE_AUTH=false

# =====================================================================
# ADDON PACKAGES
# =====================================================================
# Persistent Python addon packages installed into the uv-managed venv
# under /opt/data. The profile's requirements.txt is used by default.
# Set HERMES_ADDON_REQUIREMENTS to override, or set to empty to disable.

HERMES_ADDON_PYTHON_VERSION=3.13

# =====================================================================
# SSH AND ANSIBLE
# =====================================================================
# Profile defaults differ: personal-assistant has SSH=false, Ansible=false;
# universal-system-architect has both=true. Set explicitly to override.

HERMES_SSH_KEY_TYPE=ed25519
HERMES_SSH_KEY_PATH=/opt/data/.ssh/id_ed25519
HERMES_ANSIBLE_VERSION=14.1.0

# Uncomment to override profile defaults:
# HERMES_SSH_SETUP=true
# HERMES_ANSIBLE_SETUP=true

# =====================================================================
# PASSWORD POLICY
# =====================================================================
# Used by maintain.sh rotate-passwords. Options: production (default) or lab.
# Production policy rejects weak passwords (<14 chars, missing categories).

HERMES_PASSWORD_POLICY=production